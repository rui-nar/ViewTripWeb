# ViewTripWeb — server runtime environment variables.
#
# These are read by the FastAPI backend at RUNTIME (os.getenv), NOT at build
# time. A value passed to `docker build` or to `flutter build` does NOT reach
# the running server — it must be in the container's (or shell's) environment
# when the process starts.
#
# Copy this file to `.env` and fill in the blanks. The real `.env` is
# gitignored — never commit secrets.
#
#   Local dev (manual uvicorn):
#     export $(grep -v '^#' .env | xargs) && uvicorn api.router:app --reload
#   Local dev (Windows):
#     dev.ps1 / dev-server.ps1 already inject these for you.
#   Docker / NAS:
#     reference this file from docker-compose.yml ->  env_file: .env
#     then `docker compose up -d` to (re)create the container so it picks the
#     new values up (a plain `restart` does NOT apply env changes).

# Mapbox access token — used two ways:
#   1. CLIENT BUILD-TIME define used by the dev scripts (dev.ps1 /
#      dev-client.ps1) as `--dart-define=MAPBOX_TOKEN=...`, bundled into the
#      Flutter web build for the interactive map.
#   2. SERVER RUNTIME (os.getenv, issue #14): read by src/poster/tile_stitcher.py
#      to fetch raster tiles for poster basemap generation. Falls back to
#      config/config.json's mapbox.token when unset.
MAPBOX_TOKEN=

# Google Translate v2 API key — enables the memory translation endpoints.
# When unset, the server logs a warning and /api/memories/.../translate fails
# at runtime. Optional (translation is the only feature affected).
GOOGLE_TRANSLATE_API_KEY=

# Google OAuth client id for "Sign in with Google". Takes priority over
# config/config.json's google.client_id. Optional if that file provides it.
GOOGLE_CLIENT_ID=

# SQLAlchemy database URL. Defaults to a local sqlite file when unset.
# Example: sqlite:////data/viewtripweb.db
DATABASE_URL=

# Transactional email (issue #113) — any provider's SMTP relay works (Brevo,
# Resend, SES, Postmark, ...); switching providers is just changing these.
# All optional: when SMTP_HOST is unset, the server logs emails to the
# console instead of sending them, so it never fails to start without these.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# From address. Falls back to SMTP_USERNAME when unset.
MAIL_FROM=
